{
  "name": "threshold-backrooms",
  "private": true,
  "version": "4.1.0",
  "description": "An immersive three-level Backrooms survival-horror game with cooperative multiplayer and spatial voice chat.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duolahypercho/backrooms.git"
  },
  "homepage": "https://github.com/duolahypercho/backrooms#readme",
  "bugs": {
    "url": "https://github.com/duolahypercho/backrooms/issues"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node server/dev-server.js",
    "dev:game": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "validate:content": "node scripts/validate-content.js",
    "preview": "vite preview",
    "server:multiplayer": "node server/multiplayer-server.js"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.178.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.178.1",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^7.0.4"
  }
}
