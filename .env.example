# Browser build: public WebSocket endpoint used by every player.
VITE_MULTIPLAYER_URL=ws://127.0.0.1:8787/multiplayer

# Optional JSON array. Keep empty for local/LAN host-candidate voice.
VITE_VOICE_ICE_SERVERS=[]

# Multiplayer server: pass these through your process manager or shell.
MULTIPLAYER_HOST=0.0.0.0
MULTIPLAYER_PORT=8787
MULTIPLAYER_PATH=/multiplayer
# Rooms are designed for four players; lower this to 2 or 3 if desired.
MULTIPLAYER_MAX_PLAYERS=4
