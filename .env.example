# Browser build (Vite). VITE_* values are public and compiled into the client.
# Local default:
VITE_MULTIPLAYER_URL=ws://127.0.0.1:8787/multiplayer
# Production example:
# VITE_MULTIPLAYER_URL=wss://rooms.example.com/multiplayer

# Optional JSON array. Keep empty for local/LAN host-candidate voice.
# Public voice usually needs STUN and may require TURN. Use temporary TURN
# credentials because every VITE_* value is visible to browser users.
VITE_VOICE_ICE_SERVERS=[]
# VITE_VOICE_ICE_SERVERS=[{"urls":"stun:stun.example.com:3478"},{"urls":"turns:turn.example.com:5349","username":"TEMPORARY_USERNAME","credential":"TEMPORARY_CREDENTIAL"}]

# Multiplayer server runtime. Set these in the hosting platform, process
# manager, or shell; the Node server does not automatically load this file.
MULTIPLAYER_HOST=0.0.0.0
MULTIPLAYER_PORT=8787
MULTIPLAYER_PATH=/multiplayer
# Rooms are designed for four players; 2, 3, and 4 are accepted.
MULTIPLAYER_MAX_PLAYERS=4

# Rooms are stored in this one process. Keep backend scaling fixed at one
# instance until a shared room store and pub/sub coordination are added.
